<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Paws Relax Inn – Cat Boarding Registration</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal-50: #E1F5EE;
    --teal-400: #1D9E75;
    --teal-600: #0F6E56;
    --teal-800: #085041;
    --radius-md: 8px;
    --radius-lg: 12px;
    --bg: #F4F4F2;
    --surface: #FFFFFF;
    --border: rgba(0,0,0,0.12);
    --border-md: rgba(0,0,0,0.22);
    --text-primary: #1a1a1a;
    --text-secondary: #666;
    --text-hint: #999;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a1a;
      --surface: #242424;
      --border: rgba(255,255,255,0.1);
      --border-md: rgba(255,255,255,0.2);
      --text-primary: #f0f0f0;
      --text-secondary: #aaa;
      --text-hint: #666;
      --teal-50: #0d2e22;
      --teal-800: #9fe6c8;
    }
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    color: var(--text-primary);
  }

  .shell {
    max-width: 480px;
    margin: 0 auto;
    padding-bottom: 48px;
  }

  /* Hero */
  .hero {
    background: var(--teal-400);
    padding: 32px 20px 26px;
    color: #fff;
  }
  .hero-sub {
    font-size: 11px;
    opacity: .7;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .hero-title {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.25;
  }
  .hero-icon {
    font-size: 36px;
    float: right;
    margin-top: -4px;
  }

  /* Section card */
  .section-block {
    background: var(--surface);
    margin: 14px 14px 0;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    overflow: hidden;
  }
  .section-header {
    background: var(--teal-50);
    padding: 11px 16px;
    border-bottom: 0.5px solid var(--border);
  }
  .section-header span {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .1em;
    font-weight: 600;
    color: var(--teal-800);
  }
  .fields { padding: 18px 16px; }
  .field { margin-bottom: 18px; }
  .field:last-child { margin-bottom: 0; }

  /* Labels */
  label {
    display: block;
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 7px;
    font-weight: 500;
  }
  label .req { color: var(--teal-400); margin-left: 2px; }

  /* Inputs */
  input[type=text],
  input[type=tel],
  input[type=number],
  input[type=date],
  input[type=password],
  textarea {
    width: 100%;
    font-size: 15px;
    padding: 11px 13px;
    border: 0.5px solid var(--border-md);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text-primary);
    outline: none;
    font-family: inherit;
    -webkit-appearance: none;
    appearance: none;
  }
  input:focus, textarea:focus {
    border-color: var(--teal-400);
    box-shadow: 0 0 0 3px rgba(29,158,117,.15);
  }
  textarea { resize: none; line-height: 1.6; }
  input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }

  /* Radio pills */
  .radio-group { display: flex; gap: 8px; }
  .radio-opt { flex: 1; }
  .radio-opt input[type=radio] { display: none; }
  .radio-opt label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 10px 6px;
    border: 0.5px solid var(--border-md);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 400;
    transition: all .15s;
    user-select: none;
    text-align: center;
  }
  .radio-opt label i { font-size: 15px; }
  .radio-opt input:checked + label {
    background: var(--teal-50);
    border-color: var(--teal-400);
    color: var(--teal-800);
    font-weight: 600;
  }

  /* Upload */
  .upload-box {
    border: 0.5px dashed var(--border-md);
    border-radius: var(--radius-md);
    padding: 22px 16px;
    text-align: center;
    cursor: pointer;
    transition: all .15s;
    position: relative;
  }
  .upload-box:hover { border-color: var(--teal-400); background: var(--teal-50); }
  .upload-box input[type=file] {
    position: absolute; inset: 0; opacity: 0;
    cursor: pointer; width: 100%; height: 100%;
  }
  .upload-icon { font-size: 26px; color: var(--text-hint); display: block; margin-bottom: 7px; }
  .upload-text { font-size: 13px; color: var(--text-secondary); }
  .upload-name { font-size: 13px; color: var(--teal-600); margin-top: 6px; font-weight: 500; }

  /* Submit button */
  .submit-row { padding: 14px; }
  .btn-submit {
    width: 100%;
    padding: 16px;
    background: var(--teal-400);
    color: #fff;
    border: none;
    border-radius: var(--radius-lg);
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: .01em;
    transition: background .15s;
    font-family: inherit;
  }
  .btn-submit:hover { background: var(--teal-600); }
  .btn-submit:active { transform: scale(.98); }

  /* Thank you banner */
  .thankyou {
    display: none;
    margin: 18px 14px 0;
    background: var(--teal-50);
    border: 0.5px solid var(--teal-400);
    border-radius: var(--radius-lg);
    padding: 32px 20px;
    text-align: center;
  }
  .thankyou.show { display: block; }
  .thankyou-emoji { font-size: 44px; margin-bottom: 14px; }
  .thankyou-title {
    font-size: 19px;
    font-weight: 600;
    color: var(--teal-800);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .thankyou-sub {
    font-size: 14px;
    color: var(--teal-600);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .btn-new {
    display: inline-block;
    padding: 11px 28px;
    background: var(--teal-400);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-new:hover { background: var(--teal-600); }

  /* Admin trigger */
  .admin-trigger {
    text-align: center;
    padding: 28px 12px 8px;
    font-size: 18px;
    color: var(--border-md);
    cursor: pointer;
    user-select: none;
    transition: color .15s;
  }
  .admin-trigger:hover { color: var(--text-hint); }

  /* Admin panel */
  .admin-panel {
    display: none;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    margin: 0 14px;
    overflow: hidden;
  }
  .admin-panel.open { display: block; }
  .admin-panel-head {
    background: var(--teal-50);
    padding: 11px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 0.5px solid var(--border);
  }
  .admin-panel-head span {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .1em;
    font-weight: 600;
    color: var(--teal-800);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .count-badge {
    background: var(--teal-400);
    color: #fff;
    border-radius: 99px;
    font-size: 11px;
    padding: 2px 8px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
  }
  .btn-lock {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    color: var(--teal-600);
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: inherit;
    padding: 4px 6px;
  }
  .admin-btns { display: flex; gap: 10px; padding: 14px; }
  .btn-adm {
    flex: 1;
    padding: 11px 8px;
    font-size: 13px;
    font-weight: 500;
    border: 0.5px solid var(--border-md);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: inherit;
    transition: background .12s;
  }
  .btn-adm:hover { background: var(--bg); }
  .btn-adm.accent {
    background: var(--teal-50);
    border-color: var(--teal-400);
    color: var(--teal-800);
    font-weight: 600;
  }

  /* Modal overlay */
  .modal-wrap {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-wrap.open { display: flex; }
  .modal {
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    width: 100%;
    max-width: 340px;
    overflow: hidden;
  }
  .modal-head {
    padding: 16px 20px;
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .modal-head span { font-size: 15px; font-weight: 600; }
  .modal-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 22px;
    line-height: 1;
    padding: 2px 4px;
  }
  .modal-body { padding: 20px; }
  .modal-body label { margin-bottom: 8px; }
  .pin-error {
    font-size: 12px;
    color: #E24B4A;
    margin-top: 8px;
    display: none;
  }
  .pin-error.show { display: block; }
  .btn-unlock {
    width: 100%;
    margin-top: 14px;
    padding: 13px;
    background: var(--teal-400);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-unlock:hover { background: var(--teal-600); }

  /* Records modal */
  .records-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    z-index: 200;
    align-items: flex-start;
    justify-content: center;
    padding: 16px;
    overflow-y: auto;
  }
  .records-modal.open { display: flex; }
  .records-box {
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    width: 100%;
    max-width: 480px;
    margin: auto;
    overflow: hidden;
  }
  .records-head {
    padding: 14px 18px;
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    background: var(--surface);
    z-index: 1;
  }
  .records-head span { font-size: 15px; font-weight: 600; }
  .record-card {
    padding: 14px 18px;
    border-bottom: 0.5px solid var(--border);
  }
  .record-card:last-child { border-bottom: none; }
  .record-cat { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
  .record-row { font-size: 13px; color: var(--text-secondary); margin-bottom: 2px; display: flex; gap: 6px; }
  .record-row i { font-size: 14px; flex-shrink: 0; margin-top: 1px; }
  .no-records { padding: 32px; text-align: center; color: var(--text-hint); font-size: 14px; }
  .btn-del {
    background: none;
    border: 0.5px solid #E24B4A33;
    color: #E24B4A;
    border-radius: var(--radius-md);
    font-size: 12px;
    padding: 4px 10px;
    cursor: pointer;
    margin-top: 8px;
    font-family: inherit;
  }
  .btn-del:hover { background: #FCEBEB; }
</style>
</head>
<body>

<div class="shell">
  <div class="hero">
    <div class="hero-sub">Paws Relax Inn</div>
    <div class="hero-title">Cat Boarding<br>Registration <span class="hero-icon">🐾</span></div>
  </div>

  <!-- Thank you banner -->
  <div class="thankyou" id="thankYou">
    <div class="thankyou-emoji">🐱</div>
    <div class="thankyou-title">Thank you for trusting<br>Paws Relax Inn!</div>
    <div class="thankyou-sub">We've received your booking request and will be in touch on WhatsApp shortly. We look forward to taking care of your furry family member!</div>
    <button class="btn-new" onclick="resetForm()">Submit another booking</button>
  </div>

  <!-- Booking form -->
  <form id="boardingForm">

    <div class="section-block">
      <div class="section-header"><span>General Information</span></div>
      <div class="fields">

        <div class="field">
          <label>Cat's name <span class="req">*</span></label>
          <input type="text" name="catName" placeholder="e.g. Luna" required autocomplete="off">
        </div>

        <div class="field">
          <label>Cat parent's name <span class="req">*</span></label>
          <input type="text" name="parentName" placeholder="Your full name" required autocomplete="name">
        </div>

        <div class="field">
          <label>Cat's age</label>
          <input type="number" name="catAge" placeholder="Age in years" min="0" max="30">
        </div>

        <div class="field">
          <label>Neutered / Spayed</label>
          <div class="radio-group">
            <div class="radio-opt">
              <input type="radio" name="neutered" id="n-yes" value="Neutered">
              <label for="n-yes"><i class="ti ti-check"></i> Neutered</label>
            </div>
            <div class="radio-opt">
              <input type="radio" name="neutered" id="n-spayed" value="Spayed">
              <label for="n-spayed"><i class="ti ti-check"></i> Spayed</label>
            </div>
            <div class="radio-opt">
              <input type="radio" name="neutered" id="n-no" value="No">
              <label for="n-no"><i class="ti ti-x"></i> No</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Vaccination status</label>
          <div class="radio-group">
            <div class="radio-opt">
              <input type="radio" name="vaccinated" id="v-yes" value="Yes">
              <label for="v-yes"><i class="ti ti-shield-check"></i> Vaccinated</label>
            </div>
            <div class="radio-opt">
              <input type="radio" name="vaccinated" id="v-no" value="No">
              <label for="v-no"><i class="ti ti-shield-x"></i> Not yet</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Upload vaccination card</label>
          <div class="upload-box" id="uploadBox">
            <input type="file" name="vaccinationCard" accept="image/*,.pdf" id="fileInput">
            <i class="ti ti-upload upload-icon"></i>
            <div class="upload-text">Tap to upload image or PDF</div>
            <div class="upload-name" id="fileName"></div>
          </div>
        </div>

        <div class="field">
          <label>WhatsApp number <span class="req">*</span></label>
          <input type="tel" name="whatsapp" placeholder="+968 XXXX XXXX" required autocomplete="tel">
        </div>

      </div>
    </div>

    <div class="section-block">
      <div class="section-header"><span>Boarding Information</span></div>
      <div class="fields">

        <div class="field">
          <label>Pickup service needed?</label>
          <div class="radio-group">
            <div class="radio-opt">
              <input type="radio" name="pickup" id="p-yes" value="Yes">
              <label for="p-yes"><i class="ti ti-car"></i> Yes please</label>
            </div>
            <div class="radio-opt">
              <input type="radio" name="pickup" id="p-no" value="No">
              <label for="p-no"><i class="ti ti-walk"></i> I'll drop off</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Departure date <span class="req">*</span></label>
          <input type="date" name="departureDate" required>
        </div>

        <div class="field">
          <label>Return / arrival date <span class="req">*</span></label>
          <input type="date" name="arrivalDate" required>
        </div>

        <div class="field">
          <label>Preferred food</label>
          <div class="radio-group">
            <div class="radio-opt">
              <input type="radio" name="food" id="f-owner" value="Owner's food">
              <label for="f-owner"><i class="ti ti-home"></i> My own</label>
            </div>
            <div class="radio-opt">
              <input type="radio" name="food" id="f-hotel" value="Paws Relax Inn">
              <label for="f-hotel"><i class="ti ti-building"></i> Paws Relax Inn</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Feeding schedule</label>
          <textarea name="feedingSchedule" rows="3" placeholder="e.g. 7am – half cup dry food&#10;1pm – wet food pouch&#10;7pm – half cup dry food"></textarea>
        </div>

        <div class="field">
          <label>Special instructions</label>
          <textarea name="specialInstructions" rows="3" placeholder="Allergies, medications, behaviour notes, comfort items…"></textarea>
        </div>

      </div>
    </div>

    <div class="submit-row">
      <button type="submit" class="btn-submit">Submit Booking Request</button>
    </div>

  </form>

  <!-- Admin panel (shown after PIN unlock) -->
  <div class="admin-panel" id="adminPanel">
    <div class="admin-panel-head">
      <span>Admin Panel <span class="count-badge" id="recCount">0</span></span>
      <button class="btn-lock" onclick="lockAdmin()"><i class="ti ti-lock"></i> Lock</button>
    </div>
    <div class="admin-btns">
      <button class="btn-adm accent" onclick="openRecordsModal()"><i class="ti ti-table"></i> View records</button>
      <button class="btn-adm" onclick="exportExcel()"><i class="ti ti-download"></i> Export Excel</button>
    </div>
  </div>

  <!-- Subtle admin gear trigger -->
  <div class="admin-trigger" id="adminTrigger" onclick="openLoginModal()" title="Owner access">⚙</div>
</div>

<!-- PIN login modal -->
<div class="modal-wrap" id="loginModal">
  <div class="modal">
    <div class="modal-head">
      <span>Owner access</span>
      <button class="modal-close" onclick="closeLoginModal()">×</button>
    </div>
    <div class="modal-body">
      <label>Enter your PIN</label>
      <input type="password" id="pinInput" placeholder="••••" maxlength="10"
        onkeydown="if(event.key==='Enter') tryLogin()" autocomplete="off">
      <div class="pin-error" id="pinError">Incorrect PIN. Please try again.</div>
      <button class="btn-unlock" onclick="tryLogin()">Unlock</button>
    </div>
  </div>
</div>

<!-- Records modal -->
<div class="records-modal" id="recordsModal">
  <div class="records-box">
    <div class="records-head">
      <span>Booking records</span>
      <button class="modal-close" onclick="closeRecordsModal()">×</button>
    </div>
    <div id="recordsList"></div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'paws_relax_bookings';
  const ADMIN_PIN   = '1611';

  // File upload label
  document.getElementById('fileInput').addEventListener('change', function () {
    document.getElementById('fileName').textContent =
      this.files[0] ? '✓ ' + this.files[0].name : '';
  });

  // Storage helpers
  function getRecords() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
    catch (e) { return []; }
  }
  function saveRecords(r) { localStorage.setItem(STORAGE_KEY, JSON.stringify(r)); }
  function updateCount() {
    document.getElementById('recCount').textContent = getRecords().length;
  }
  updateCount();

  // Form submit
  document.getElementById('boardingForm').addEventListener('submit', function (e) {
    e.preventDefault();
    const fd = new FormData(this);
    const entry = { id: Date.now(), submittedAt: new Date().toLocaleString('en-GB') };
    fd.forEach((v, k) => { if (k !== 'vaccinationCard') entry[k] = v; });
    const fi = document.getElementById('fileInput');
    if (fi.files[0]) entry.vaccinationCard = fi.files[0].name;
    const records = getRecords();
    records.push(entry);
    saveRecords(records);
    updateCount();
    // Show thank you, hide form
    this.style.display = 'none';
    document.getElementById('thankYou').classList.add('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Reset form
  function resetForm() {
    document.getElementById('thankYou').classList.remove('show');
    const f = document.getElementById('boardingForm');
    f.reset();
    f.style.display = '';
    document.getElementById('fileName').textContent = '';
    document.querySelectorAll('input[type=radio]').forEach(r => r.checked = false);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Admin login
  function openLoginModal() {
    document.getElementById('loginModal').classList.add('open');
    document.getElementById('pinInput').value = '';
    document.getElementById('pinError').classList.remove('show');
    setTimeout(() => document.getElementById('pinInput').focus(), 150);
  }
  function closeLoginModal() {
    document.getElementById('loginModal').classList.remove('open');
  }
  function tryLogin() {
    if (document.getElementById('pinInput').value === ADMIN_PIN) {
      closeLoginModal();
      document.getElementById('adminPanel').classList.add('open');
      document.getElementById('adminTrigger').style.display = 'none';
      updateCount();
    } else {
      document.getElementById('pinError').classList.add('show');
      document.getElementById('pinInput').value = '';
      document.getElementById('pinInput').focus();
    }
  }
  function lockAdmin() {
    document.getElementById('adminPanel').classList.remove('open');
    document.getElementById('adminTrigger').style.display = '';
  }

  // Records modal
  function openRecordsModal() {
    const records = getRecords();
    const list = document.getElementById('recordsList');
    if (!records.length) {
      list.innerHTML = '<div class="no-records">No bookings yet.</div>';
    } else {
      list.innerHTML = records.slice().reverse().map(r => `
        <div class="record-card" id="rec-${r.id}">
          <div class="record-cat">🐱 ${r.catName || '—'}</div>
          <div class="record-row"><i class="ti ti-user"></i>${r.parentName || '—'}</div>
          <div class="record-row"><i class="ti ti-brand-whatsapp"></i>${r.whatsapp || '—'}</div>
          <div class="record-row"><i class="ti ti-calendar"></i>${r.departureDate || '—'} → ${r.arrivalDate || '—'}</div>
          <div class="record-row"><i class="ti ti-shield-check"></i>Vaccinated: ${r.vaccinated || '—'} &nbsp;|&nbsp; Neutered: ${r.neutered || '—'}</div>
          <div class="record-row"><i class="ti ti-car"></i>Pickup: ${r.pickup || '—'} &nbsp;|&nbsp; Food: ${r.food || '—'}</div>
          ${r.feedingSchedule ? `<div class="record-row"><i class="ti ti-clock"></i>${r.feedingSchedule}</div>` : ''}
          ${r.specialInstructions ? `<div class="record-row"><i class="ti ti-note"></i>${r.specialInstructions}</div>` : ''}
          <div class="record-row" style="color:var(--text-hint);font-size:12px"><i class="ti ti-calendar-time"></i>Submitted: ${r.submittedAt}</div>
          <button class="btn-del" onclick="deleteRecord(${r.id})">Delete entry</button>
        </div>
      `).join('');
    }
    document.getElementById('recordsModal').classList.add('open');
  }
  function closeRecordsModal() {
    document.getElementById('recordsModal').classList.remove('open');
  }
  function deleteRecord(id) {
    if (!confirm('Delete this booking entry?')) return;
    const updated = getRecords().filter(r => r.id !== id);
    saveRecords(updated);
    updateCount();
    openRecordsModal();
  }

  // Export to Excel
  function exportExcel() {
    const records = getRecords();
    if (!records.length) { alert('No records to export yet.'); return; }
    const headers = [
      'Submitted At', 'Cat Name', 'Parent Name', 'Cat Age',
      'Neutered/Spayed', 'Vaccinated', 'Vaccination Card', 'WhatsApp',
      'Pickup', 'Departure Date', 'Arrival Date',
      'Preferred Food', 'Feeding Schedule', 'Special Instructions'
    ];
    const keys = [
      'submittedAt', 'catName', 'parentName', 'catAge',
      'neutered', 'vaccinated', 'vaccinationCard', 'whatsapp',
      'pickup', 'departureDate', 'arrivalDate',
      'food', 'feedingSchedule', 'specialInstructions'
    ];
    const rows = [headers, ...records.map(r => keys.map(k => r[k] || ''))];
    const ws = XLSX.utils.aoa_to_sheet(rows);
    ws['!cols'] = headers.map(() => ({ wch: 24 }));
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Bookings');
    const date = new Date().toISOString().slice(0,10);
    XLSX.writeFile(wb, `PawsRelaxInn_Bookings_${date}.xlsx`);
  }

  // Close modals on backdrop click
  document.getElementById('loginModal').addEventListener('click', function(e){
    if (e.target === this) closeLoginModal();
  });
  document.getElementById('recordsModal').addEventListener('click', function(e){
    if (e.target === this) closeRecordsModal();
  });
</script>
</body>
</html>
